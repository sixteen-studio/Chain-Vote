              <ButtonLink
                href="/candidates"
                size="lg"
                variant="outline"
                className="border-primary/20 hover:border-border-strong text-text-secondary hover:text-text-primary bg-transparent gap-2 px-8 text-base"
              >
                Lihat Kandidat
