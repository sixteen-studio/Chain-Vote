  const { isDark, toggleTheme, mounted } = useTheme();

  if (!mounted) {
    return (
      <div
        className={cn(
          "w-8 h-8 rounded-lg bg-bg-card border border-primary/20 opacity-0 pointer-events-none",
          className
        )}
        aria-hidden
