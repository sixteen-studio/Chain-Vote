-- CreateTrigger: trg_vote_tampering
-- Trigger AFTER INSERT OR UPDATE OR DELETE pada tabel VoteRecord.
-- Hanya bereaksi pada UPDATE dan DELETE (INSERT adalah operasi normal via API).
